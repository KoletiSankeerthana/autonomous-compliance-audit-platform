# ============================================================
# Enterprise Compliance AI Platform — Environment Configuration
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# ============================================================

# ---- Application ----
APP_NAME="Enterprise Compliance AI Platform"
ENVIRONMENT=development
DEBUG=false

# ---- API ----
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Database (Supabase PostgreSQL) ----
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ---- Authentication ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Admin Bootstrap (first run only) ----
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeMe123!

# ---- LLM Provider (choose one for production) ----
# Supported: groq | openai | gemini | ollama (local dev only)
LLM_PROVIDER=groq

# Groq (RECOMMENDED for production — free tier at https://console.groq.com)
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama3-8b-8192

# OpenAI (paid — https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (free tier — https://aistudio.google.com)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Legacy Ollama (local development only — NOT available on Render)
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ---- ChromaDB ----
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=documents

# ---- File Storage ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=text

# ---- MCP: Local Files ----
MCP_LOCAL_FILES_DIR=./mcp_documents

# ---- MCP: Google Drive ----
# Set path to service account JSON file
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# ---- MCP: Notion ----
NOTION_API_TOKEN=
NOTION_DATABASE_ID=
